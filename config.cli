batch

module add --name=com.mysql --resources=target/SistemaGestionMovilidad/WEB-INF/lib/mysql-connector-j-8.3.0.jar --dependencies=javax.api,javax.transaction.api

/subsystem=datasources/jdbc-driver=mysql:add(driver-name=mysql,driver-module-name=com.mysql,driver-xa-datasource-class-name=com.mysql.cj.jdbc.MysqlXADataSource)

data-source add --name=MySQLDS --jndi-name=java:jboss/datasources/MySQLDS --connection-url=jdbc:mysql://localhost:3306/sistema_movilidad?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true --driver-name=mysql --user-name=root --enabled=true

run-batch